{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/news.html",
      "destination": "/news.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ]
}
